# GitHub Configuration
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_PAT=ghp_your_personal_access_token_here

# Gemini AI (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# GCP / Vertex AI (optional — only if not using GEMINI_API_KEY)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/reviewmind

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0

# App Settings
ENVIRONMENT=development
PORT=8000
